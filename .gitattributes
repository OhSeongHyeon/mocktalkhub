# 기본: 텍스트는 자동 감지 + 리포에는 LF로 고정
* text=auto eol=lf

# Windows 전용 스크립트는 CRLF 유지
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
# 쉘 스크립트는 LF 강제
*.sh  text eol=lf

*.py          text eol=lf
*.yml         text eol=lf
*.yaml        text eol=lf
*.toml        text eol=lf
*.ini         text eol=lf
*.cfg         text eol=lf
*.conf        text eol=lf
*.env*        text eol=lf
Dockerfile    text eol=lf
*.md          text eol=lf

*.png   binary
*.jpg   binary
*.jpeg  binary
*.zip   binary
*.tar   binary
*.gz    binary
